---
import { Image } from 'astro:assets';
import fondoPapel from '../assets/fondo-papel.jpg';
import florIzquierda from '../assets/plantas.png';
import florDerecha from '../assets/plantas.png';

import fondoSeccionInferior from '../assets/fondo-detalles.jpeg';
import selloBoda from '../assets/sello-boda.png';
---

<div id="details-block" class="relative w-full overflow-hidden">

    <Image
            src={fondoPapel}
            alt=""
            class="absolute inset-0 w-full h-full object-cover z-0 opacity-60 pointer-events-none"
    />
    <div class="absolute inset-0 bg-[#f3ede2]/50 z-10 pointer-events-none"></div>

    <div class="absolute z-30 pointer-events-none
                -left-12 -top-20 scale-[0.5] lg:scale-120 lg:-top-8 rotate-75">
        <Image src={florIzquierda} alt="" class="w-auto h-[350px] md:h-[500px] object-contain" />
    </div>

    <div class="absolute z-30 pointer-events-none
                -right-15 top-20 scale-[0.6] lg:scale-130 lg:-right-10 lg:top-10 -rotate-50">
        <Image src={florDerecha} alt="" class="w-auto h-[350px] md:h-[500px] object-contain" />
    </div>

    <div class="relative z-30 w-full flex flex-col items-center py-16 md:py-24 px-4 text-center text-stone-800">
        <main class="w-full max-w-4xl mx-auto px-2 relative">

            <div class="w-full p-8 md:p-12 flex flex-col items-center justify-center gap-6">
                <div class="max-w-2xl">
                    <p class="font-body text-[#2c2616] tracking-[0.15em] italic uppercase text-lg md:text-4xl leading-relaxed">
                        “Nosotros le amamos a él,<br />
                        porque él nos amó primero”
                    </p>
                </div>
                <div>
                    <p class="font-body text-stone-500 text-sm md:text-xl tracking-[0.3em] uppercase">
                        1 Juan 4:19
                    </p>
                </div>
            </div>

            <div class="absolute left-1/2 -bottom-45 lg:-bottom-80 xl:-bottom-105 -translate-x-1/2 z-40 w-50 h-50 lg:w-100 lg:h-100 xl:w-150 xl:h-150 pointer-events-none">
                <Image
                        src={selloBoda}
                        alt="Sello personalizado"
                        class="w-full h-full object-contain drop-shadow-md"
                />
            </div>

        </main>
    </div>

    <section class="relative z-20 w-full min-h-screen overflow-hidden flex items-center justify-center border-t border-[#2c2616]/5 p-6 md:p-12">

        <Image
                src={fondoSeccionInferior}
                alt="Fondo sección detalles"
                class="absolute inset-0 w-full h-full object-cover z-0"
        />

        <div class="absolute inset-0 bg-[#2c2616]/15 z-10 pointer-events-none"></div>

        <div class="relative z-30 w-full max-w-xl bg-[#f6f0e4] p-10 md:p-16 rounded-xl rounded-tr-[80px] md:rounded-tr-[120px] shadow-2xl text-center border border-[#2c2616]/10 mx-auto">

            <p class="font-body text-[#2c2616] text-sm md:text-2xl tracking-[0.4em] uppercase mb-10 border-b border-[#2c2616]/10 pb-4 inline-block">
                12 | SEPTIEMBRE | 2026
            </p>

            <h4 class="font-wedding italic text-4xl md:text-5xl tracking-[0.2em] text-[#2c2616] mb-8 leading-none">
                Ceremonia y Recepción
            </h4>

            <div class="flex items-center justify-center gap-10 md:gap-16 font-wedding text-[#c5b4a0] text-base md:text-3xl tracking-[0.1em] italic mb-10">
                <p>5:00 pm</p>
                <p>6:30 pm</p>
            </div>

            <div class="space-y-3 font-body text-[#2c2616] tracking-[0.2em] uppercase leading-relaxed mb-12">
                <p class="text-xl md:text-3xl">Quinta Mónaco</p>
                <p class="text-[10px] md:text-base opacity-70">
                    C. 33 912, Chichí Suárez,<br />
                    97306 Mérida, Yuc.
                </p>
            </div>

            <a
                    href="https://share.google/y2t4GXhlz9ShCzhOb"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block font-body text-[#a68e6b] text-xs md:text-lg tracking-[0.3em] uppercase border border-[#a68e6b] rounded-full px-8 md:px-12 py-3 md:py-4 transition-all duration-300 hover:bg-[#a68e6b] hover:text-white hover:shadow-lg active:scale-95"
            >
                Ver ubicación
            </a>
        </div>

    </section>

</div>

<style>
    #details-block {
        min-height: 50vh;
    }
</style>