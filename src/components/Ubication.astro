---
import { Image } from 'astro:assets';
import fondoPapel from '../assets/fondo-papel-2.jpg';
import florIzquierda from '../assets/plantas.png';
import florDerecha from '../assets/plantas.png';


import fondoSeccionInferior from '../assets/fondo-detalles.jpeg';
import selloBoda from '../assets/sello-boda.png';
---

<div id="details-block" class="relative w-full overflow-hidden">

    <Image
            src={fondoPapel}
            alt=""
            class="absolute inset-0 w-full h-full object-cover z-0 opacity-60 pointer-events-none"
    />
    <div class="absolute inset-0 bg-[#f3ede2]/50 z-10 pointer-events-none"></div>

    <div class="absolute z-30 pointer-events-none
                -left-12 top-10 scale-[0.5] md:scale-120 md:-top-8 rotate-75">
        <Image src={florIzquierda} alt="" class="w-auto h-[350px] md:h-[500px] object-contain" />
    </div>

    <div class="absolute z-30 pointer-events-none
                -right-15 top-40 scale-[0.6] md:scale-130 md:-right-10 md:top-10 -rotate-50">
        <Image src={florDerecha} alt="" class="w-auto h-[350px] md:h-[500px] object-contain" />
    </div>

    <div class="relative z-30 w-full flex flex-col items-center py-16 md:py-24 px-4 text-center text-stone-800">
        <main class="w-full max-w-4xl mx-auto px-2 relative">

            <div class="w-full p-8 md:p-12 flex flex-col items-center justify-center gap-6">
                <div class="max-w-2xl">
                    <p class="font-body text-[#2c2616] tracking-[0.15em] italic uppercase text-lg md:text-4xl leading-relaxed">
                        “Nosotros le amamos a él,<br />
                        porque él nos amó primero”
                    </p>
                </div>
                <div>
                    <p class="font-body text-stone-500 text-sm md:text-xl tracking-[0.3em] uppercase">
                        1 Juan 4:19
                    </p>
                </div>
            </div>

            <div class="absolute left-1/2 -bottom-20 md:-bottom-110 -translate-x-1/2 z-40 w-32 h-32 md:w-150 md:h-150 pointer-events-none">
                <Image
                        src={selloBoda}
                        alt="Sello personalizado"
                        class="w-full h-full object-contain drop-shadow-md"
                />
            </div>

        </main>
    </div>

    <section class="relative z-20 w-full min-h-[400px] md:min-h-[600px] overflow-hidden flex flex-col md:flex-row border-t border-[#2c2616]/5">

        <Image
                src={fondoSeccionInferior}
                alt="Fondo sección detalles"
                class="absolute inset-0 w-full h-full object-cover z-0"
        />

        <div class="absolute inset-0 bg-[#2c2616]/10 z-10"></div>

        <div class="relative z-20 w-full flex items-center justify-center">
            <p class="font-wedding text-4xl text-white drop-shadow-lg opacity-80">
                Contenido Próximamente
            </p>
        </div>

    </section>

</div>

<style>
    #details-block {
        min-height: 50vh;
    }
</style>