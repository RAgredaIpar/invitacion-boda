---
import { Image } from 'astro:assets';

import foto1 from '../assets/galeria/foto1.jpg';
import foto2 from '../assets/galeria/foto2.jpg';
import foto3 from '../assets/galeria/foto3.jpg';
import foto4 from '../assets/galeria/foto4.jpg';
import foto5 from '../assets/galeria/foto5.jpg';
import foto6 from '../assets/galeria/foto6.jpg';
import foto7 from '../assets/galeria/foto7.jpg';
import foto8 from '../assets/galeria/foto8.jpg';
import foto9 from '../assets/galeria/foto9.jpg';
---

<section id="galeria" class="w-full bg-[#f6f0e4] py-20 px-4 md:px-10">

    <div class="text-center mb-16">
        <h2 class="font-wedding text-4xl md:text-6xl text-[#2c2616] italic tracking-wide">
            Nuestros momentos felices
        </h2>
    </div>

    <div class="max-w-[1400px] mx-auto space-y-4">

        <div class="flex flex-col md:flex-row gap-4 h-auto md:h-[500px]">
            <div class="gallery-item w-full md:w-[60%] h-[300px] md:h-full overflow-hidden rounded-sm opacity-0 translate-y-10 transition-all duration-1000">
                <Image
                        src={foto1}
                        alt="Momento 1"
                        class="w-full h-full object-cover object-[50%_50%]"
                />
            </div>
            <div class="gallery-item w-full md:w-[40%] h-[300px] md:h-full overflow-hidden rounded-sm opacity-0 translate-y-10 transition-all duration-1000">
                <Image
                        src={foto2}
                        alt="Momento 2"
                        class="w-full h-full object-cover object-[50%_50%]"
                />
            </div>
        </div>

        <div class="gallery-item w-full h-[350px] md:h-[600px] overflow-hidden rounded-sm opacity-0 translate-y-10 transition-all duration-1000">
            <Image
                    src={foto3}
                    alt="Momento 3"
                    class="w-full h-full object-cover object-[50%_50%]"
            />
        </div>

        <div class="flex flex-col md:flex-row gap-4 h-auto md:h-[450px]">
            <div class="gallery-item w-full md:w-[30%] h-[250px] md:h-full overflow-hidden rounded-sm opacity-0 translate-y-10 transition-all duration-1000">
                <Image
                        src={foto4}
                        alt="Momento 4"
                        class="w-full h-full object-cover object-[50%_50%]"
                />
            </div>
            <div class="gallery-item w-full md:w-[40%] h-[300px] md:h-full overflow-hidden rounded-sm opacity-0 translate-y-10 transition-all duration-1000">
                <Image
                        src={foto5}
                        alt="Momento 5"
                        class="w-full h-full object-cover object-[50%_50%]"
                />
            </div>
            <div class="gallery-item w-full md:w-[30%] h-[250px] md:h-full overflow-hidden rounded-sm opacity-0 translate-y-10 transition-all duration-1000">
                <Image
                        src={foto6}
                        alt="Momento 6"
                        class="w-full h-full object-cover object-[50%_50%]"
                />
            </div>
        </div>

        <div class="flex flex-col md:flex-row gap-4 h-auto md:h-[450px]">
            <div class="gallery-item w-full md:w-[30%] h-[250px] md:h-full overflow-hidden rounded-sm opacity-0 translate-y-10 transition-all duration-1000">
                <Image
                        src={foto7}
                        alt="Momento 7"
                        class="w-full h-full object-cover object-[50%_50%]"
                />
            </div>
            <div class="gallery-item w-full md:w-[30%] h-[250px] md:h-full overflow-hidden rounded-sm opacity-0 translate-y-10 transition-all duration-1000">
                <Image
                        src={foto8}
                        alt="Momento 8"
                        class="w-full h-full object-cover object-[50%_50%]"
                />
            </div>
            <div class="gallery-item w-full md:w-[40%] h-[300px] md:h-full overflow-hidden rounded-sm opacity-0 translate-y-10 transition-all duration-1000">
                <Image
                        src={foto9}
                        alt="Momento 9"
                        class="w-full h-full object-cover object-[50%_90%]"
                />
            </div>
        </div>

    </div>
</section>

<script>
    const galleryItems = document.querySelectorAll('.gallery-item');

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const target = entry.target as HTMLElement;
                target.style.opacity = "1";
                target.style.transform = "translateY(0)";
                target.style.filter = "blur(0)";
            }
        });
    }, {
        threshold: 0.1,
        rootMargin: "0px 0px -50px 0px"
    });

    galleryItems.forEach(item => {
        (item as HTMLElement).style.filter = "blur(10px)";
        observer.observe(item);
    });
</script>

<style>
    img {
        transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .overflow-hidden:hover img {
        transform: scale(1.05);
    }
</style>