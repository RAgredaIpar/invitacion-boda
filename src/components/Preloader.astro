<div id="preloader" class="fixed inset-0 z-[100] flex items-center justify-center bg-[#f6f0e4]">
    <div id="preloader-content" class="flex flex-col items-center opacity-0 translate-y-4 transition-all duration-1000 ease-out">
        <h1 class="font-wedding text-7xl md:text-9xl text-[#2c2616] italic tracking-tighter">
            J & E
        </h1>
        <div id="preloader-line" class="w-0 h-[1px] bg-[#2c2616]/30 mx-auto mt-4 transition-all duration-[1500ms] ease-in-out"></div>
    </div>
</div>

<script>
    function startPreloader() {
        const preloader = document.getElementById('preloader');
        const content = document.getElementById('preloader-content');
        const line = document.getElementById('preloader-line');

        setTimeout(() => {
            if (content) content.style.opacity = "1";
            if (content) content.style.transform = "translateY(0)";
            if (line) line.style.width = "100px";
        }, 100);

        setTimeout(() => {
            if (preloader) {
                preloader.style.opacity = "0";
                preloader.style.transition = "opacity 1s ease-in-out";

                document.body.classList.add('preloader-done');

                document.documentElement.style.overflow = "auto";
                document.body.style.overflow = "auto";

                setTimeout(() => {
                    preloader.style.display = "none";
                }, 1000);
            }
        }, 2500);
    }

    if (document.readyState === 'complete') {
        startPreloader();
    } else {
        window.addEventListener('load', startPreloader);
    }
</script>