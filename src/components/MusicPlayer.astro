---
---
<div id="music-player-root" class="fixed bottom-6 right-6 z-[50] flex flex-col items-center gap-3 opacity-0 transition-all duration-1000 group">

    <div id="volume-control" class="flex flex-col items-center justify-center bg-[#f6f0e4]/90 backdrop-blur-md border border-[#2c2616]/20 w-12 h-40 rounded-full shadow-2xl opacity-0 translate-y-4 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-500 ease-out">

        <div class="relative w-full h-32 flex items-center justify-center">
            <label for="volume-slider"></label><input
                    type="range"
                    id="volume-slider"
                    min="0"
                    max="1"
                    step="0.01"
                    value="0.5"
                    class="absolute accent-[#2c2616] cursor-pointer w-28 -rotate-90 appearance-none bg-transparent touch-none"
            />
        </div>

        <span class="text-[9px] font-body text-[#2c2616] mb-4 uppercase tracking-widest font-bold opacity-60">Vol</span>
    </div>

    <button
            id="music-btn"
            class="relative flex items-center justify-center w-12 h-12 md:w-14 md:h-14 bg-[#2c2616]/10 backdrop-blur-md border border-[#2c2616]/20 rounded-full hover:bg-[#2c2616]/20 transition-all duration-300 shadow-xl active:scale-90"
    >
        <div id="bars-container" class="flex items-end gap-[3px] h-4">
            <div class="bar w-[3px] bg-[#2c2616] rounded-full h-2"></div>
            <div class="bar w-[3px] bg-[#2c2616] rounded-full h-4"></div>
            <div class="bar w-[3px] bg-[#2c2616] rounded-full h-3"></div>
            <div class="bar w-[3px] bg-[#2c2616] rounded-full h-5"></div>
        </div>
        <div id="mute-slash" class="absolute w-7 h-[2px] bg-[#2c2616] rotate-45 scale-x-0 transition-transform duration-300 origin-center"></div>
    </button>

    <audio id="wedding-audio" loop>
        <source src="/musica-boda.mp3" type="audio/mpeg" />
    </audio>
</div>

<script>
    const root = document.getElementById('music-player-root');
    const audio = document.getElementById('wedding-audio') as HTMLAudioElement;
    const btn = document.getElementById('music-btn');
    const slider = document.getElementById('volume-slider') as HTMLInputElement;
    const slash = document.getElementById('mute-slash');
    const bars = document.querySelectorAll('.bar');

    audio.volume = 0.5;

    const updateVisuals = (muted: boolean) => {
        if (muted || audio.volume === 0) {
            slash?.classList.add('scale-x-100');
            slash?.classList.remove('scale-x-0');
            bars.forEach(bar => (bar as HTMLElement).style.animationPlayState = 'paused');
        } else {
            slash?.classList.add('scale-x-0');
            slash?.classList.remove('scale-x-100');
            bars.forEach(bar => (bar as HTMLElement).style.animationPlayState = 'running');
        }
    };

    const playAudio = () => {
        audio.play().then(() => {
            updateVisuals(audio.muted);
            window.removeEventListener('touchstart', playAudio);
            window.removeEventListener('click', playAudio);
        }).catch(() => {});
    };

    btn?.addEventListener('click', (e) => {
        e.stopPropagation();
        audio.muted = !audio.muted;
        updateVisuals(audio.muted);
    });

    slider?.addEventListener('input', (e) => {
        const val = parseFloat((e.target as HTMLInputElement).value);
        audio.volume = val;
        updateVisuals(audio.muted);
    });

    document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
            audio.pause();
        } else {
            if (!audio.muted && audio.volume > 0) {
                audio.play().catch(() => {});
            }
        }
    });

    slider?.addEventListener('touchmove', (e) => e.stopPropagation(), { passive: false });

    const observer = new MutationObserver(() => {
        if (document.body.classList.contains('preloader-done')) {
            if (root) root.style.opacity = "1";
            playAudio();
            window.addEventListener('touchstart', playAudio, { once: true });
            window.addEventListener('click', playAudio, { once: true });
            observer.disconnect();
        }
    });
    observer.observe(document.body, { attributes: true });
</script>

<style>
    .bar {
        animation: soundWave 1.2s ease-in-out infinite alternate;
        animation-play-state: paused;
        transition: height 0.3s ease;
    }

    .bar:nth-child(2) { animation-delay: 0.2s; }
    .bar:nth-child(3) { animation-delay: 0.4s; }
    .bar:nth-child(4) { animation-delay: 0.1s; }

    @keyframes soundWave {
        0% { height: 4px; }
        100% { height: 16px; }
    }

    .touch-none {
        touch-action: none;
    }

    #volume-slider::-webkit-slider-runnable-track {
        width: 100%;
        height: 4px;
        background: rgba(44, 38, 22, 0.1);
        border-radius: 2px;
    }

    #volume-slider::-webkit-slider-thumb {
        appearance: none;
        width: 18px;
        height: 18px;
        background: #2c2616;
        border-radius: 50%;
        margin-top: -7px;
        cursor: pointer;
        border: none;
    }

    #volume-slider::-moz-range-track {
        width: 100%;
        height: 4px;
        background: rgba(44, 38, 22, 0.1);
        border-radius: 2px;
    }

    #volume-slider::-moz-range-thumb {
        width: 18px;
        height: 18px;
        background: #2c2616;
        border-radius: 50%;
        cursor: pointer;
        border: none;
    }
</style>