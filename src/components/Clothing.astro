---
import { Image } from 'astro:assets';
// Asegúrate de tener estas imágenes en tu carpeta assets
import fondoVestimenta from '../assets/fondo-vestimenta.jpg'; // La foto de ustedes
import iconoPrendas from '../assets/trajes.svg'; // Los dibujos de traje y vestido
---

<section id="dress-code-section" class="relative w-full min-h-screen md:h-[80vh] flex items-center overflow-hidden">

    <Image
            src={fondoVestimenta}
            alt="Código de vestimenta"
            class="absolute inset-0 w-full h-full object-cover z-0 object-[22%_50%] sm:object-[25%_50%]xl:object-center"
    />

    <div class="absolute inset-0 bg-black/30 md:bg-transparent md:bg-gradient-to-r md:from-transparent md:to-black/60 z-10"></div>

    <div class="relative z-20 w-full max-w-7xl mx-auto px-6 md:px-12 flex flex-col md:flex-row items-center">

        <div class="hidden md:block md:w-1/2"></div>

        <div class="w-full md:w-1/2 flex flex-col items-center text-center text-white space-y-8">

            <h2 class="font-wedding text-4xl md:text-6xl tracking-[0.1em] drop-shadow-md">
                Código de vestimenta
            </h2>

            <div class="w-40 md:w-56 opacity-90 drop-shadow-lg">
                <Image
                        src={iconoPrendas}
                        alt="Traje y Vestido"
                        class="w-full h-auto object-contain"
                />
            </div>

            <div class="space-y-4">
                <p class="font-body text-2xl md:text-4xl tracking-[0.3em] uppercase font-light">
                    Formal
                </p>
            </div>

            <a
                    href="https://pin.it/6hCMsug30"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block font-body text-white text-xs md:text-lg tracking-[0.3em] uppercase border border-white/60 rounded-full px-8 md:px-12 py-3 md:py-4 transition-all duration-300 hover:bg-white hover:text-black hover:shadow-lg active:scale-95 bg-black/20 backdrop-blur-sm"
            >
                Ver ideas
            </a>

        </div>
    </div>
</section>

<style>
    #dress-code-section h2 {
        font-style: italic;
    }
</style>